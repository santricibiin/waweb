# =========================================
# Database (MySQL)
# =========================================
DATABASE_URL="mysql://root:password@localhost:3306/wa_otp"

# =========================================
# Next.js Web App
# =========================================
# JWT secret for dashboard session cookie
JWT_SECRET="ganti-dengan-string-acak-panjang-min-32-karakter"

# Public URL for the website (used in docs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal URL of the WhatsApp worker (called server-side only)
WORKER_URL="http://localhost:4000"

# Shared secret between Next.js <-> WhatsApp worker
WORKER_INTERNAL_TOKEN="rahasia-internal-antara-web-dan-worker"

# =========================================
# WhatsApp Worker
# =========================================
WORKER_PORT=4000
# Folder for storing Baileys auth state per session
WA_AUTH_DIR="./auth-sessions"
